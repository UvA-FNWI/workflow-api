{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Step",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Internal name of the step"
    },
    "title": {
      "description": "Localized title of the step as shown to user",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        },
        {
          "$ref": "#/definitions/BilingualString"
        }
      ]
    },
    "progress": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "description": "The progress information about the step",
          "$ref": "#/definitions/ProgressInformation"
        }
      ]
    },
    "icon": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "description": "The icon of the step",
          "$ref": "#/definitions/Icon"
        }
      ]
    },
    "hierarchyMode": {
      "description": "Determines how the child steps of this step are handled",
      "$ref": "#/definitions/StepHierarchyMode"
    },
    "children": {
      "type": "array",
      "description": "Child steps of this step",
      "items": {
        "type": "string"
      }
    },
    "headerStatus": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/definitions/StepHeaderStatusConfiguration"
      }
    },
    "condition": {
      "description": "Condition requires for this step to start",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        },
        {
          "$ref": "#/definitions/Condition"
        }
      ]
    },
    "actions": {
      "type": "array",
      "description": "Actions that are possible while this step is active",
      "items": {
        "$ref": "#/definitions/Action"
      }
    },
    "ends": {
      "description": "Condition that determines when the step ends",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        },
        {
          "$ref": "#/definitions/Condition"
        }
      ]
    },
    "properties": {
      "type": "array",
      "description": "Properties related to this step. These will become properties of the corresponding entity",
      "items": {
        "$ref": "#/definitions/PropertyDefinition"
      }
    },
    "events": {
      "type": "array",
      "description": "Events defined within this step. These will be merged into the workflow definition's events.",
      "items": {
        "$ref": "#/definitions/EventDefinition"
      }
    }
  },
  "definitions": {
    "BilingualString": {
      "title": "BilingualString",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "en",
        "nl"
      ],
      "properties": {
        "en": {
          "type": "string"
        },
        "nl": {
          "type": "string"
        }
      }
    },
    "ProgressInformation": {
      "title": "ProgressInformation",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "color": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/definitions/StatusColor"
            }
          ]
        },
        "text": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        }
      }
    },
    "StatusColor": {
      "type": "string",
      "enum": [
        "Red",
        "Green"
      ]
    },
    "Icon": {
      "title": "Icon",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "color": {
          "$ref": "#/definitions/StatusColor"
        }
      }
    },
    "StepHierarchyMode": {
      "type": "string",
      "enum": [
        "Sequential",
        "Parallel"
      ]
    },
    "StepHeaderStatusConfiguration": {
      "title": "StepHeaderStatusConfiguration",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label"
      ],
      "properties": {
        "event": {
          "type": [
            "null",
            "string"
          ]
        },
        "condition": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/Condition"
            }
          ]
        },
        "type": {
          "$ref": "#/definitions/StepHeaderPillType"
        },
        "label": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        }
      }
    },
    "Condition": {
      "title": "Condition",
      "type": "object",
      "description": "Represents a logical condition",
      "additionalProperties": false,
      "properties": {
        "not": {
          "type": "boolean",
          "description": "If true, this condition is inverted"
        },
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Compare property values",
              "$ref": "#/definitions/Value"
            }
          ]
        },
        "logical": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "For and/or constructs",
              "$ref": "#/definitions/Logical"
            }
          ]
        },
        "event": {
          "description": "Check if an event has occurred",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/EventCondition"
            }
          ]
        },
        "date": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Check if a date has passed",
              "$ref": "#/definitions/Date"
            }
          ]
        },
        "deadline": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Check if a deadline has passed",
              "$ref": "#/definitions/Deadline"
            }
          ]
        },
        "name": {
          "type": [
            "null",
            "string"
          ],
          "description": "Use a named reusable condition"
        },
        "message": {
          "description": "Message that is shown then the condition is not, for use in form validation",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        }
      }
    },
    "Value": {
      "title": "Value",
      "type": "object",
      "description": "Represents a value comparison. Use this to compare two properties, or to compare a property to a fixed literal value\n            (prefix a string value with an equals sign to indicate a literal value)",
      "additionalProperties": false,
      "required": [
        "property"
      ],
      "properties": {
        "property": {
          "type": "string",
          "description": "Target property"
        },
        "equal": {
          "type": [
            "null",
            "string"
          ],
          "description": "Value the property should be equal to. If this is a literal string, it must be prefixed with an equals sign"
        },
        "lessThan": {
          "type": [
            "null",
            "string"
          ],
          "description": "Value the property should be less than"
        },
        "greaterThan": {
          "type": [
            "null",
            "string"
          ],
          "description": "Value the property should be greater than"
        },
        "greaterThanOrEqual": {
          "type": [
            "null",
            "string"
          ],
          "description": "Value the property should be greater than or equal to"
        },
        "in": {
          "type": [
            "null",
            "string"
          ],
          "description": "Array the property should be in"
        },
        "isEmpty": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "If set, check whether the property is empty"
        },
        "maxLength": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum length of a string"
        }
      }
    },
    "Logical": {
      "title": "Logical",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "operator": {
          "$ref": "#/definitions/LogicalOperator"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Condition"
          }
        }
      }
    },
    "LogicalOperator": {
      "type": "string",
      "enum": [
        "And",
        "Or"
      ]
    },
    "EventCondition": {
      "title": "EventCondition",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Id of the event to check for"
        }
      }
    },
    "Date": {
      "title": "Date",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "type": "string"
        }
      }
    },
    "Deadline": {
      "title": "Deadline",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expressionText"
      ],
      "properties": {
        "expressionText": {
          "type": "string"
        }
      }
    },
    "StepHeaderPillType": {
      "type": "string",
      "enum": [
        "Info",
        "Attention",
        "Success"
      ]
    },
    "Action": {
      "title": "Action",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": [
            "null",
            "string"
          ],
          "description": "Internal name of the action. Required for actions of type execute"
        },
        "label": {
          "description": "Localized label of the action as shown in the user interface",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        },
        "intent": {
          "$ref": "#/definitions/ActionIntent"
        },
        "roles": {
          "type": "array",
          "description": "List of roles that can perform this action",
          "items": {
            "type": "string"
          }
        },
        "form": {
          "type": [
            "null",
            "string"
          ],
          "description": "Target form for View / Submit / Edit actions"
        },
        "forms": {
          "type": "array",
          "description": "List of target forms for View / Submit / Edit actions",
          "items": {
            "type": "string"
          }
        },
        "collections": {
          "type": "array",
          "description": "List of target collections for ??? (not yet implemented)",
          "items": {
            "type": "string"
          }
        },
        "propertyDefinition": {
          "type": [
            "null",
            "string"
          ],
          "description": "Target propertyDefinition for the view hidden propertyDefinition action"
        },
        "workflowDefinition": {
          "type": [
            "null",
            "string"
          ]
        },
        "type": {
          "description": "Type of action",
          "$ref": "#/definitions/RoleAction"
        },
        "condition": {
          "description": "Condition that determines whether the action is permitted",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/Condition"
            }
          ]
        },
        "onAction": {
          "type": "array",
          "description": "List of effects to run for an Execute action",
          "items": {
            "$ref": "#/definitions/Effect"
          }
        },
        "steps": {
          "type": "array",
          "description": "List of steps during which this action is permitted",
          "items": {
            "type": "string"
          }
        },
        "noAutoOpenForm": {
          "type": "boolean",
          "description": "When true, the submit form does not automatically even if it is the only submit action in the step"
        },
        "property": {
          "type": [
            "null",
            "string"
          ],
          "description": "Target property for the CreateRelatedInstance action"
        },
        "userProperty": {
          "type": [
            "null",
            "string"
          ],
          "description": "Weird thing, maybe we should get rid of this?"
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Weird thing, maybe we should get rid of this?"
        }
      }
    },
    "ActionIntent": {
      "type": "string",
      "enum": [
        "Primary",
        "Secondary",
        "Destructive"
      ]
    },
    "RoleAction": {
      "type": "string",
      "enum": [
        "View",
        "Submit",
        "Edit",
        "Undo",
        "ViewAdminTools",
        "Execute",
        "ViewHidden",
        "ViewUsers",
        "ViewStates",
        "Delete",
        "AddInstanceMessage",
        "ViewAnswerMessages",
        "AssignMessages",
        "CreateInstance",
        "CreateRelatedInstance",
        "ImpersonateRoles"
      ]
    },
    "Effect": {
      "title": "Effect",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": [
            "null",
            "string"
          ],
          "description": "Optional effect name, used to refer to outputs of this effect"
        },
        "condition": {
          "description": "Condition that determines if this trigger is active",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/Condition"
            }
          ]
        },
        "sendMail": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Send an email",
              "$ref": "#/definitions/SendMessage"
            }
          ]
        },
        "showConfetti": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Show confetti"
        },
        "toast": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Show a toast message",
              "$ref": "#/definitions/Toast"
            }
          ]
        },
        "http": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Do an http call to an external service",
              "$ref": "#/definitions/Http"
            }
          ]
        },
        "setProperty": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Set a property on the current instance",
              "$ref": "#/definitions/SetProperty"
            }
          ]
        },
        "serviceCall": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Call an external service",
              "$ref": "#/definitions/ServiceCall"
            }
          ]
        },
        "redirect": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Redirect the user to an url",
              "$ref": "#/definitions/Redirect"
            }
          ]
        },
        "createExternalUserAccount": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Create external login access for the assigned user or users of a workflow role",
              "$ref": "#/definitions/CreateExternalUserAccount"
            }
          ]
        },
        "event": {
          "type": [
            "null",
            "string"
          ],
          "description": "Complete an event"
        },
        "undoEvent": {
          "type": [
            "null",
            "string"
          ],
          "description": "Undo an event"
        },
        "delay": {
          "type": [
            "null",
            "string"
          ],
          "description": "Run the effect after this delay, e.g. 2d, 4h or 30m"
        }
      }
    },
    "SendMessage": {
      "title": "SendMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "to": {
          "description": "Recipients: each entry is a property lookup (User or [User]) or a literal email address.",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "toAddress": {
          "type": [
            "null",
            "string"
          ],
          "description": "Literal recipient address (templated). Prefer 'to' with an email address."
        },
        "cc": {
          "description": "Cc recipients, resolved like 'to'.",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "bcc": {
          "description": "Bcc recipients, resolved like 'to'.",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "subject": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        },
        "body": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        },
        "template": {
          "type": [
            "null",
            "string"
          ]
        },
        "layout": {
          "type": [
            "null",
            "string"
          ]
        },
        "buttons": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SendMessageButton"
          }
        },
        "sendAsMail": {
          "type": "boolean"
        },
        "sendAutomatically": {
          "type": "boolean"
        },
        "attachments": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Attachment"
          }
        }
      }
    },
    "SendMessageButton": {
      "title": "SendMessageButton",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "label"
      ],
      "properties": {
        "url": {
          "type": "string"
        },
        "label": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        },
        "intent": {
          "$ref": "#/definitions/MailButtonIntent"
        }
      }
    },
    "MailButtonIntent": {
      "type": "string",
      "enum": [
        "Primary"
      ]
    },
    "Attachment": {
      "title": "Attachment",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template"
      ],
      "properties": {
        "template": {
          "type": "string"
        }
      }
    },
    "Toast": {
      "title": "Toast",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message"
      ],
      "properties": {
        "type": {
          "description": "Toast type to show in the frontend",
          "$ref": "#/definitions/ToastType"
        },
        "message": {
          "description": "Toast message to show in the frontend",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        }
      }
    },
    "ToastType": {
      "type": "string",
      "enum": [
        "Success",
        "Error",
        "Info",
        "Warning",
        "Note"
      ]
    },
    "Http": {
      "title": "Http",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string",
          "description": "Template for the url to call"
        }
      }
    },
    "SetProperty": {
      "title": "SetProperty",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "property",
        "value"
      ],
      "properties": {
        "property": {
          "type": "string",
          "description": "Target property name"
        },
        "value": {
          "type": "string",
          "description": "Expression that determines the value of the property"
        }
      }
    },
    "ServiceCall": {
      "title": "ServiceCall",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service",
        "operation"
      ],
      "properties": {
        "service": {
          "type": "string"
        },
        "operation": {
          "type": "string"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "Redirect": {
      "title": "Redirect",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string"
        }
      }
    },
    "CreateExternalUserAccount": {
      "title": "CreateExternalUserAccount",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role"
      ],
      "properties": {
        "role": {
          "type": "string",
          "description": "Name of the workflow role/property that holds the target user or users"
        }
      }
    },
    "PropertyDefinition": {
      "title": "PropertyDefinition",
      "type": "object",
      "description": "Represents a property of an entity type (which can also be used as a propertyDefinition in a form)",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Internal name of the propertyDefinition"
        },
        "text": {
          "description": "Localized text of the propertyDefinition",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        },
        "visibility": {
          "description": "Set if this propertyDefinition is hidden from users without extra permissions",
          "$ref": "#/definitions/PropertyVisibility"
        },
        "layout": {
          "description": "Specific layout options for the data type",
          "oneOf": [
            {
              "$ref": "#/definitions/ChoiceLayoutOptions"
            },
            {
              "$ref": "#/definitions/TextLayoutOptions"
            },
            {
              "$ref": "#/definitions/TableLayoutOptions"
            },
            {
              "type": "null"
            }
          ]
        },
        "shortText": {
          "description": "Localized short propertyDefinition text to shown in results",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        },
        "type": {
          "type": "string",
          "description": "Data type of the propertyDefinition. Can be a primitive type String, Int, Double, DateTime, Date, User, Currency, File, Boolean\n            or a reference to a value set or another entity type. Use [Type] to indicate an array and Type! to indicate\n            a required value."
        },
        "values": {
          "type": [
            "array",
            "null"
          ],
          "description": "Values for a choice propertyDefinition.",
          "items": {
            "$ref": "#/definitions/Choice"
          }
        },
