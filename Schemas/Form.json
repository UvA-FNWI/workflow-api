{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Form",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Internal name of the form"
    },
    "title": {
      "description": "Bilingual title of the form",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        },
        {
          "$ref": "#/definitions/BilingualString"
        }
      ]
    },
    "inheritsFrom": {
      "type": [
        "null",
        "string"
      ],
      "description": "Name of the parent form to inherit pages from"
    },
    "layout": {
      "description": "Sets whether this form shows the inherited pages in a normal layout or a compact layout, or opens in a modal",
      "$ref": "#/definitions/FormLayout"
    },
    "property": {
      "type": [
        "null",
        "string"
      ],
      "description": "Target reference property. Set this to use the form to update the properties of the referenced entity"
    },
    "targetForm": {
      "type": [
        "null",
        "string"
      ],
      "description": "To be used in combination with Property. The name of a form for the referenced entity type"
    },
    "step": {
      "type": [
        "null",
        "string"
      ],
      "description": "Step this form belongs to"
    },
    "pages": {
      "type": "array",
      "description": "Dictionary of pages of this form",
      "items": {
        "$ref": "#/definitions/Page"
      }
    },
    "onSubmit": {
      "type": "array",
      "description": "Effect to run when the form is submitted",
      "items": {
        "$ref": "#/definitions/Effect"
      }
    },
    "emitFormSubmitEvent": {
      "type": "boolean",
      "description": "Whether submitting the form should emit the form-name event."
    },
    "submittedWhenEvents": {
      "type": [
        "array",
        "null"
      ],
      "description": "Event ids that determine whether the form is considered submitted.\n            If omitted, the form-name event is used.",
      "items": {
        "type": "string"
      }
    },
    "onSave": {
      "type": "array",
      "description": "Effect to run when a change is made in the form",
      "items": {
        "$ref": "#/definitions/Effect"
      }
    }
  },
  "definitions": {
    "BilingualString": {
      "title": "BilingualString",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "en",
        "nl"
      ],
      "properties": {
        "en": {
          "type": "string"
        },
        "nl": {
          "type": "string"
        }
      }
    },
    "FormLayout": {
      "type": "string",
      "enum": [
        "Normal",
        "Compact",
        "Modal"
      ]
    },
    "Page": {
      "title": "Page",
      "type": "object",
      "description": "Represents a page in a form",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Internal name of the page"
        },
        "title": {
          "description": "Localized title of the page",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        },
        "introduction": {
          "description": "Localized introduction text to show at the start of the page",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        },
        "layout": {
          "description": "Layout of the page. Condensed will show the questions in a table",
          "$ref": "#/definitions/PageLayout"
        },
        "fields": {
          "type": "array",
          "description": "PropertyDefinition names to include in the page",
          "items": {
            "type": "string"
          }
        },
        "sources": {
          "type": [
            "array",
            "null"
          ],
          "description": "If set, this page is included only when editing a matching property",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PageLayout": {
      "type": "string",
      "enum": [
        "Normal",
        "Condensed"
      ]
    },
    "Effect": {
      "title": "Effect",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": [
            "null",
            "string"
          ],
          "description": "Optional effect name, used to refer to outputs of this effect"
        },
        "condition": {
          "description": "Condition that determines if this trigger is active",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/Condition"
            }
          ]
        },
        "sendMail": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Send an email",
              "$ref": "#/definitions/SendMessage"
            }
          ]
        },
        "showConfetti": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Show confetti"
        },
        "toast": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Show a toast message",
              "$ref": "#/definitions/Toast"
            }
          ]
        },
        "http": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Do an http call to an external service",
              "$ref": "#/definitions/Http"
            }
          ]
        },
        "setProperty": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Set a property on the current instance",
              "$ref": "#/definitions/SetProperty"
            }
          ]
        },
        "serviceCall": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Call an external service",
              "$ref": "#/definitions/ServiceCall"
            }
          ]
        },
        "redirect": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Redirect the user to an url",
              "$ref": "#/definitions/Redirect"
            }
          ]
        },
        "createExternalUserAccount": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Create external login access for the assigned user or users of a workflow role",
              "$ref": "#/definitions/CreateExternalUserAccount"
            }
          ]
        },
        "event": {
          "type": [
            "null",
            "string"
          ],
          "description": "Complete an event"
        },
        "undoEvent": {
          "type": [
            "null",
            "string"
          ],
          "description": "Undo an event"
        },
        "delay": {
          "type": [
            "null",
            "string"
          ],
          "description": "Run the effect after this delay, e.g. 2d, 4h or 30m"
        }
      }
    },
    "Condition": {
      "title": "Condition",
      "type": "object",
      "description": "Represents a logical condition",
      "additionalProperties": false,
      "properties": {
        "not": {
          "type": "boolean",
          "description": "If true, this condition is inverted"
        },
        "value": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Compare property values",
              "$ref": "#/definitions/Value"
            }
          ]
        },
        "logical": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "For and/or constructs",
              "$ref": "#/definitions/Logical"
            }
          ]
        },
        "event": {
          "description": "Check if an event has occurred",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/EventCondition"
            }
          ]
        },
        "date": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Check if a date has passed",
              "$ref": "#/definitions/Date"
            }
          ]
        },
        "deadline": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "description": "Check if a deadline has passed",
              "$ref": "#/definitions/Deadline"
            }
          ]
        },
        "name": {
          "type": [
            "null",
            "string"
          ],
          "description": "Use a named reusable condition"
        },
        "message": {
          "description": "Message that is shown then the condition is not, for use in form validation",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        }
      }
    },
    "Value": {
      "title": "Value",
      "type": "object",
      "description": "Represents a value comparison. Use this to compare two properties, or to compare a property to a fixed literal value\n            (prefix a string value with an equals sign to indicate a literal value)",
      "additionalProperties": false,
      "required": [
        "property"
      ],
      "properties": {
        "property": {
          "type": "string",
          "description": "Target property"
        },
        "equal": {
          "type": [
            "null",
            "string"
          ],
          "description": "Value the property should be equal to. If this is a literal string, it must be prefixed with an equals sign"
        },
        "lessThan": {
          "type": [
            "null",
            "string"
          ],
          "description": "Value the property should be less than"
        },
        "greaterThan": {
          "type": [
            "null",
            "string"
          ],
          "description": "Value the property should be greater than"
        },
        "greaterThanOrEqual": {
          "type": [
            "null",
            "string"
          ],
          "description": "Value the property should be greater than or equal to"
        },
        "in": {
          "type": [
            "null",
            "string"
          ],
          "description": "Array the property should be in"
        },
        "isEmpty": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "If set, check whether the property is empty"
        },
        "maxLength": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum length of a string"
        }
      }
    },
    "Logical": {
      "title": "Logical",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "operator": {
          "$ref": "#/definitions/LogicalOperator"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Condition"
          }
        }
      }
    },
    "LogicalOperator": {
      "type": "string",
      "enum": [
        "And",
        "Or"
      ]
    },
    "EventCondition": {
      "title": "EventCondition",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Id of the event to check for"
        }
      }
    },
    "Date": {
      "title": "Date",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "type": "string"
        }
      }
    },
    "Deadline": {
      "title": "Deadline",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expressionText"
      ],
      "properties": {
        "expressionText": {
          "type": "string"
        }
      }
    },
    "SendMessage": {
      "title": "SendMessage",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "to": {
          "description": "Recipients: each entry is a property lookup (User or [User]), a literal email address, or a template.",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "cc": {
          "description": "Cc recipients, resolved like 'to'.",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "bcc": {
          "description": "Bcc recipients, resolved like 'to'.",
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "subject": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        },
        "body": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        },
        "template": {
          "type": [
            "null",
            "string"
          ]
        },
        "layout": {
          "type": [
            "null",
            "string"
          ]
        },
        "buttons": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SendMessageButton"
          }
        },
        "sendAsMail": {
          "type": "boolean"
        },
        "sendAutomatically": {
          "type": "boolean"
        },
        "attachments": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Attachment"
          }
        }
      }
    },
    "SendMessageButton": {
      "title": "SendMessageButton",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "label"
      ],
      "properties": {
        "url": {
          "type": "string"
        },
        "label": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        },
        "intent": {
          "$ref": "#/definitions/MailButtonIntent"
        }
      }
    },
    "MailButtonIntent": {
      "type": "string",
      "enum": [
        "Primary"
      ]
    },
    "Attachment": {
      "title": "Attachment",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template"
      ],
      "properties": {
        "template": {
          "type": "string"
        }
      }
    },
    "Toast": {
      "title": "Toast",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message"
      ],
      "properties": {
        "type": {
          "description": "Toast type to show in the frontend",
          "$ref": "#/definitions/ToastType"
        },
        "message": {
          "description": "Toast message to show in the frontend",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/definitions/BilingualString"
            }
          ]
        }
      }
    },
    "ToastType": {
      "type": "string",
      "enum": [
        "Success",
        "Error",
        "Info",
        "Warning",
        "Note"
      ]
    },
    "Http": {
      "title": "Http",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string",
          "description": "Template for the url to call"
        }
      }
    },
    "SetProperty": {
      "title": "SetProperty",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "property",
        "value"
      ],
      "properties": {
        "property": {
          "type": "string",
          "description": "Target property name"
        },
        "value": {
          "type": "string",
          "description": "Expression that determines the value of the property"
        }
      }
    },
    "ServiceCall": {
      "title": "ServiceCall",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service",
        "operation"
      ],
      "properties": {
        "service": {
          "type": "string"
        },
        "operation": {
          "type": "string"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "Redirect": {
      "title": "Redirect",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string"
        }
      }
    },
    "CreateExternalUserAccount": {
      "title": "CreateExternalUserAccount",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role"
      ],
      "properties": {
        "role": {
          "type": "string",
          "description": "Name of the workflow role/property that holds the target user or users"
        }
      }
    }
  }
}